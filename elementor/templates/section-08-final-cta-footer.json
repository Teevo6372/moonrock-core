                { "id": "final-c2-btn", "elType": "widget", "widgetType": "button", "settings": { "text": "Chat with Nova", "link": { "url": "#nova-chat" }, "button_size": "md", "_css_classes": "moonrock-btn moonrock-btn--primary", "width": "100" } }
              ]
