                { "id": "final-c3-btn", "elType": "widget", "widgetType": "button", "settings": { "text": "Explore the Growth Hub", "link": { "url": "#growth-hub" }, "button_size": "md", "_css_classes": "moonrock-btn moonrock-btn--primary", "width": "100" } }
              ]
