              "elements": [
                { "id": "ft-contact-head", "elType": "widget", "widgetType": "heading", "settings": { "title": "Contact", "header_size": "h4", "_css_classes": "moonrock-footer__heading" } },
                { "id": "ft-contact-info", "elType": "widget", "widgetType": "text-editor", "settings": { "editor": "<p>Lawrence, Kansas<br>Helping Businesses Nationwide<br><a href=\"mailto:stephen@moonrockmarketing.com\">stephen@moonrockmarketing.com</a><br><em>Phone: [Configure in WordPress]</em><br><em>By appointment</em></p>" } }
              ]
